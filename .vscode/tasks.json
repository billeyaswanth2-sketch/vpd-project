{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", ".",
                "-B", "build",
                "-G", "MinGW Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_CXX_COMPILER=C:/msys64/ucrt64/bin/g++.exe",
                "-DCMAKE_PREFIX_PATH=C:/msys64/ucrt64",
                "-DGTest_DIR=C:/msys64/ucrt64/lib/cmake/GTest"
            ],
            "options": {
                "cwd": "${workspaceFolder}/vehicle_power_distribution"
            }
        },
        {
            "label": "Build Tests",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build"],
            "options": {
                "cwd": "${workspaceFolder}/vehicle_power_distribution"
            },
            "dependsOn": "CMake Configure",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Auto Launch Debugger",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Start-Sleep -Seconds 3; code --goto '${workspaceFolder}/vehicle_power_distribution/build/run_tests.exe'"
            ],
            "dependsOn": "Build Tests",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "problemMatcher": []
        }
    ]
}